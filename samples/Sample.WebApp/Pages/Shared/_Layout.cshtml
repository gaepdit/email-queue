@using Sample.WebApp.Settings
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sample Email Batch Viewer</title>
    <link rel="icon" href="@Url.Content("~/icon.svg")" type="image/svg+xml">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm bg-body-tertiary border-bottom box-shadow mb-3">
        <div class="container">
            <span class="navbar-brand"><a asp-page="/AllBatches" class="nav-link">Sample Email Batch Viewer</a></span>
        </div>
    </nav>
</header>

<main role="main" class="pt-2 pb-3">
    <div class="container">
        @RenderBody()
    </div>
</main>

<footer class="border-top footer text-muted">
    <div class="container"><small>
            Sample Email Batch Viewer
            @if (!string.IsNullOrEmpty(AppSettings.Version))
            {
                <span class="d-print-none">| Current version: @AppSettings.Version</span>
            }
        </small>
    </div>
</footer>

<script>
    ;(function () {
        function updateTheme() {
            let theme = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
            document.querySelector("html").setAttribute("data-bs-theme", theme);
        }

        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', updateTheme);
        updateTheme();
    })()
</script>
</body>
</html>
